{
  "Security Copilot API Plugin": {
    "prefix": "sc-api-plugin",
    "description": "Create a new Security Copilot API plugin manifest",
    "body": [
      "Descriptor:",
      "  Name: ${1:MyApiPlugin}",
      "  DisplayName: \"${2:My API Plugin}\"",
      "  Description: >",
      "    ${3:Plugin description for users and orchestrator.}",
      "  SupportedAuthTypes:",
      "    - ${4|ApiKey,Basic,AAD,None|}",
      "  Authorization:",
      "    Type: ${5|APIKey,Basic,AAD,OAuthAuthorizationCodeFlow|}",
      "    Key: ${6:x-api-key}",
      "    Location: ${7|Header,QueryString|}",
      "    AuthScheme: \"${8:}\"",
      "",
      "SkillGroups:",
      "  - Format: API",
      "    Settings:",
      "      OpenApiSpecUrl: ${9:https://example.com/openapi.yaml}",
      "$0"
    ]
  },
  "Security Copilot GPT Plugin": {
    "prefix": "sc-gpt-plugin",
    "description": "Create a new Security Copilot GPT plugin manifest",
    "body": [
      "Descriptor:",
      "  Name: ${1:MyGptPlugin}",
      "  DisplayName: \"${2:My GPT Plugin}\"",
      "  Description: >",
      "    ${3:Plugin description for users and orchestrator.}",
      "",
      "SkillGroups:",
      "  - Format: GPT",
      "    Skills:",
      "      - Name: ${4:MySkill}",
      "        DisplayName: \"${5:My Skill}\"",
      "        Description: >",
      "          ${6:Skill description.}",
      "        Inputs:",
      "          - Name: ${7:inputText}",
      "            Description: ${8:The input to process}",
      "            Required: true",
      "        Settings:",
      "          ModelName: ${9|gpt-4o,gpt-4-32k-v0613,gpt-4|}",
      "          Template: |-",
      "            ${10:Your prompt template here.}",
      "            ",
      "            {{${7:inputText}}}",
      "$0"
    ]
  },
  "Security Copilot KQL Plugin": {
    "prefix": "sc-kql-plugin",
    "description": "Create a new Security Copilot KQL plugin manifest",
    "body": [
      "Descriptor:",
      "  Name: ${1:MyKqlPlugin}",
      "  DisplayName: \"${2:My KQL Plugin}\"",
      "  Description: >",
      "    ${3:Plugin description for users and orchestrator.}",
      "",
      "SkillGroups:",
      "  - Format: KQL",
      "    Skills:",
      "      - Name: ${4:MyQuery}",
      "        DisplayName: \"${5:My Query}\"",
      "        Description: >",
      "          ${6:Query description.}",
      "        ExamplePrompts:",
      "          - \"${7:Show me the data}\"",
      "        Inputs:",
      "          - Name: ${8:timeRange}",
      "            Description: ${9:Time range for the query}",
      "            DefaultValue: \"${10:7d}\"",
      "            Required: false",
      "        Settings:",
      "          Target: ${11|Defender,Sentinel,LogAnalytics,Kusto|}",
      "          Template: |-",
      "            ${12:TableName}",
      "            | where TimeGenerated > ago({{${8:timeRange}}})",
      "            | project ${13:Column1, Column2}",
      "            | take 50",
      "$0"
    ]
  },
  "Security Copilot KQL Plugin (Sentinel)": {
    "prefix": "sc-kql-sentinel",
    "description": "Create a KQL plugin targeting Microsoft Sentinel",
    "body": [
      "Descriptor:",
      "  Name: ${1:MySentinelPlugin}",
      "  DisplayName: \"${2:My Sentinel Plugin}\"",
      "  Description: >",
      "    ${3:Plugin description.}",
      "  SupportedAuthTypes:",
      "    - None",
      "  Settings:",
      "    - Name: TenantId",
      "      Label: Tenant ID",
      "      Description: Your Azure Tenant ID",
      "      HintText: \"Enter your Azure Tenant ID\"",
      "      SettingType: string",
      "      Required: true",
      "    - Name: SubscriptionId",
      "      Label: Subscription ID",
      "      Description: Your Azure Subscription ID",
      "      HintText: \"Enter your Azure Subscription ID\"",
      "      SettingType: string",
      "      Required: true",
      "    - Name: ResourceGroupName",
      "      Label: Resource Group",
      "      Description: The resource group name",
      "      HintText: \"Enter the resource group name\"",
      "      SettingType: string",
      "      Required: true",
      "    - Name: WorkspaceName",
      "      Label: Workspace Name",
      "      Description: The Log Analytics workspace name",
      "      HintText: \"Enter the workspace name\"",
      "      SettingType: string",
      "      Required: true",
      "",
      "SkillGroups:",
      "  - Format: KQL",
      "    Skills:",
      "      - Name: ${4:MyQuery}",
      "        DisplayName: \"${5:My Query}\"",
      "        Description: >",
      "          ${6:Query description.}",
      "        ExamplePrompts:",
      "          - \"${7:Show me Sentinel data}\"",
      "        Inputs:",
      "          - Name: ${8:timeRange}",
      "            Description: Time range for the query",
      "            DefaultValue: \"7d\"",
      "            Required: false",
      "        Settings:",
      "          Target: Sentinel",
      "          TenantId: \"{{TenantId}}\"",
      "          SubscriptionId: \"{{SubscriptionId}}\"",
      "          ResourceGroupName: \"{{ResourceGroupName}}\"",
      "          WorkspaceName: \"{{WorkspaceName}}\"",
      "          Template: |-",
      "            ${9:SigninLogs}",
      "            | where TimeGenerated > ago({{${8:timeRange}}})",
      "            | take 50",
      "$0"
    ]
  },
  "Security Copilot Skill (GPT)": {
    "prefix": "sc-skill-gpt",
    "description": "Add a GPT skill to an existing plugin",
    "body": [
      "      - Name: ${1:SkillName}",
      "        DisplayName: \"${2:Skill Display Name}\"",
      "        Description: >",
      "          ${3:Skill description.}",
      "        DescriptionForModel: |",
      "          ${4:Detailed instructions for the orchestrator.}",
      "        ExamplePrompts:",
      "          - \"${5:Example prompt}\"",
      "        Inputs:",
      "          - Name: ${6:input}",
      "            Description: ${7:Input description}",
      "            Required: true",
      "        Settings:",
      "          ModelName: ${8|gpt-4o,gpt-4-32k-v0613,gpt-4|}",
      "          Template: |-",
      "            ${9:Prompt template text}",
      "            ",
      "            {{${6:input}}}",
      "$0"
    ]
  },
  "Security Copilot Skill (KQL)": {
    "prefix": "sc-skill-kql",
    "description": "Add a KQL skill to an existing plugin",
    "body": [
      "      - Name: ${1:SkillName}",
      "        DisplayName: \"${2:Skill Display Name}\"",
      "        Description: >",
      "          ${3:Skill description.}",
      "        ExamplePrompts:",
      "          - \"${4:Example prompt}\"",
      "        Inputs:",
      "          - Name: ${5:param}",
      "            Description: ${6:Parameter description}",
      "            Required: ${7|true,false|}",
      "        Settings:",
      "          Target: ${8|Defender,Sentinel,LogAnalytics,Kusto|}",
      "          Template: |-",
      "            ${9:TableName}",
      "            | where ${10:Column} == \"{{${5:param}}}\"",
      "            | take 50",
      "$0"
    ]
  },
  "Security Copilot Input": {
    "prefix": "sc-input",
    "description": "Add an input parameter to a skill",
    "body": [
      "          - Name: ${1:inputName}",
      "            Description: ${2:Description of the input}",
      "            DefaultValue: \"${3:}\"",
      "            Required: ${4|true,false|}",
      "$0"
    ]
  },
  "Security Copilot Setting": {
    "prefix": "sc-setting",
    "description": "Add a user-configurable setting",
    "body": [
      "    - Name: ${1:SettingName}",
      "      Label: ${2:Setting Label}",
      "      Description: ${3:Setting description}",
      "      HintText: \"${4:Hint text}\"",
      "      SettingType: ${5|String,string|}",
      "      Required: ${6|true,false|}",
      "$0"
    ]
  },
  "Security Copilot Authorization (API Key)": {
    "prefix": "sc-auth-apikey",
    "description": "Add API Key authorization",
    "body": [
      "  SupportedAuthTypes:",
      "    - ApiKey",
      "  Authorization:",
      "    Type: APIKey",
      "    Key: ${1:x-api-key}",
      "    Location: ${2|Header,QueryString|}",
      "    AuthScheme: \"${3:}\"",
      "$0"
    ]
  },
  "Security Copilot Authorization (OAuth)": {
    "prefix": "sc-auth-oauth",
    "description": "Add OAuth authorization",
    "body": [
      "  SupportedAuthTypes:",
      "    - AAD",
      "  Authorization:",
      "    Type: OAuthAuthorizationCodeFlow",
      "    ClientId: ${1:your-client-id}",
      "    AuthorizationEndpoint: ${2:https://login.microsoftonline.com/common/oauth2/v2.0/authorize}",
      "    TokenEndpoint: ${3:https://login.microsoftonline.com/common/oauth2/v2.0/token}",
      "    Scopes: ${4:openid profile}",
      "    AuthorizationContentType: ${5:application/x-www-form-urlencoded}",
      "$0"
    ]
  },
  "Security Copilot Authorization (Entra ID)": {
    "prefix": "sc-auth-entra",
    "description": "Add Entra ID (AAD) authorization",
    "body": [
      "  SupportedAuthTypes:",
      "    - AAD",
      "  Authorization:",
      "    Type: AAD",
      "    EntraScopes: ${1:https://graph.microsoft.com/.default}",
      "$0"
    ]
  },
  "Security Copilot Authorization (Entra ID Delegated)": {
    "prefix": "sc-auth-aad-delegated",
    "description": "Add Entra ID delegated (user + application) authorization",
    "body": [
      "  SupportedAuthTypes:",
      "    - AADDelegated",
      "  Authorization:",
      "    Type: AADDelegated",
      "    EntraScopes: ${1:https://graph.microsoft.com/.default}",
      "$0"
    ]
  },
  "Security Copilot Authorization (OAuth Client Credentials)": {
    "prefix": "sc-auth-oauth-clientcreds",
    "description": "Add OAuth 2.0 Client Credentials (server-to-server) authorization",
    "body": [
      "  SupportedAuthTypes:",
      "    - OAuthClientCredentialsFlow",
      "  Authorization:",
      "    Type: OAuthClientCredentialsFlow",
      "    TokenEndpoint: https://login.microsoftonline.com/${1:<YOUR-TENANT-ID>}/oauth2/v2.0/token",
      "    AuthorizationContentType: application/x-www-form-urlencoded",
      "$0"
    ]
  },
  "Security Copilot LogicApp Plugin": {
    "prefix": "sc-logicapp-plugin",
    "description": "Create a new Security Copilot LogicApp plugin manifest",
    "body": [
      "Descriptor:",
      "  Name: ${1:MyLogicAppPlugin}",
      "  DisplayName: \"${2:My LogicApp Plugin}\"",
      "  Description: >",
      "    ${3:Plugin description for users and orchestrator.}",
      "",
      "SkillGroups:",
      "  - Format: LogicApp",
      "    Skills:",
      "      - Name: ${4:MyLogicAppSkill}",
      "        DisplayName: \"${5:My LogicApp Skill}\"",
      "        Description: >",
      "          ${6:Skill description.}",
      "        Inputs:",
      "          - Name: ${7:inputParam}",
      "            Description: ${8:Input parameter description}",
      "            Required: true",
      "        Settings:",
      "          SubscriptionId: ${9:<YOUR-SUBSCRIPTION-ID>}",
      "          ResourceGroup: ${10:<YOUR-RESOURCE-GROUP>}",
      "          WorkflowName: ${11:MyLogicApp}",
      "          TriggerName: ${12:manual}",
      "$0"
    ]
  },
  "Security Copilot MCP Plugin": {
    "prefix": "sc-mcp-plugin",
    "description": "Create a new Security Copilot MCP plugin manifest",
    "body": [
      "Descriptor:",
      "  Name: ${1:MyMCPPlugin}",
      "  DisplayName: \"${2:My MCP Plugin}\"",
      "  Description: >",
      "    ${3:Plugin description for users and orchestrator.}",
      "  DescriptionForModel: >",
      "    ${4:Detailed instructions for the model on when and how to use the MCP tools.}",
      "",
      "SkillGroups:",
      "  - Format: MCP",
      "    Settings:",
      "      Endpoint: ${5:https://example.com/api/mcp}",
      "      TimeoutInSeconds: ${6:120}",
      "      AllowedTools: ${7:tool_name_1, tool_name_2}",
      "$0"
    ]
  },
  "Security Copilot Agent (Standard)": {
    "prefix": "sc-agent",
    "description": "Create a new Security Copilot standard agent manifest",
    "body": [
      "Descriptor:",
      "  Name: ${1:MyAgent}",
      "  DisplayName: \"${2:My Agent}\"",
      "  Description: >",
      "    ${3:Agent description.}",
      "",
      "AgentDefinitions:",
      "  - Name: ${1:MyAgent}",
      "    DisplayName: \"${2:My Agent}\"",
      "    Description: >",
      "      ${3:Agent description.}",
      "    Publisher: ${4:Custom}",
      "    Product: ${5:Security}",
      "    RequiredSkillsets:",
      "      - ${1:MyAgent}",
      "    AgentSingleInstanceConstraint: None",
      "    Triggers:",
      "      - Name: Default",
      "        DefaultPollPeriodSeconds: 0",
      "        ProcessSkill: ${1:MyAgent}.${6:AgentSkill}",
      "        FetchSkill: ''",
      "",
      "SkillGroups:",
      "  - Format: Agent",
      "    Skills:",
      "      - Name: ${6:AgentSkill}",
      "        DisplayName: \"${7:Agent Skill}\"",
      "        Description: >",
      "          ${8:Agent skill description.}",
      "        Interfaces:",
      "          - Agent",
      "        Settings:",
      "          Model: ${9|gpt-4o,gpt-4.1|}",
      "          Instructions: >-",
      "            # Mission",
      "            ${10:You are a security analyst agent.}",
      "",
      "            # Workflow",
      "            1. ${11:First step}",
      "            2. ${12:Second step}",
      "",
      "            # Output",
      "            ${13:Describe expected output format.}",
      "        ChildSkills:",
      "          - ${14:ChildSkillName}",
      "",
      "  - Format: KQL",
      "    Skills:",
      "      - Name: ${14:ChildSkillName}",
      "        DisplayName: \"${15:Child Skill}\"",
      "        Description: >",
      "          ${16:Child skill description.}",
      "        Settings:",
      "          Target: ${17|Defender,Sentinel|}",
      "          Template: |-",
      "            ${18:TableName}",
      "            | take 50",
      "$0"
    ]
  },
  "Security Copilot Agent (Interactive)": {
    "prefix": "sc-agent-interactive",
    "description": "Create a new Security Copilot interactive agent with chat experience",
    "body": [
      "Descriptor:",
      "  Name: ${1:MyInteractiveAgent}",
      "  DisplayName: \"${2:My Interactive Agent}\"",
      "  Description: >",
      "    ${3:Agent description.}",
      "",
      "AgentDefinitions:",
      "  - Name: ${1:MyInteractiveAgent}",
      "    DisplayName: \"${2:My Interactive Agent}\"",
      "    Description: >",
      "      ${3:Agent description.}",
      "    Publisher: ${4:Custom}",
      "    Product: ${5:SecurityCopilot}",
      "    RequiredSkillsets:",
      "      - ${1:MyInteractiveAgent}",
      "    AgentSingleInstanceConstraint: None",
      "    Triggers:",
      "      - Name: Default",
      "        DefaultPollPeriodSeconds: 0",
      "        ProcessSkill: ${1:MyInteractiveAgent}.${6:AgentSkill}",
      "    PromptSkill: ${1:MyInteractiveAgent}.${6:AgentSkill}",
      "",
      "SkillGroups:",
      "  - Format: Agent",
      "    Skills:",
      "      - Name: ${6:AgentSkill}",
      "        DisplayName: \"${7:Agent Skill}\"",
      "        Description: >",
      "          ${8:Agent skill description.}",
      "        Interfaces:",
      "          - InteractiveAgent",
      "        Inputs:",
      "          - Name: UserRequest",
      "            Description: The user's question or request.",
      "            DefaultValue: ''",
      "            Required: true",
      "        SuggestedPrompts:",
      "          - Prompt: ${9:Show me an overview of recent security activity}",
      "            Title: ${10:Security Overview}",
      "            Personas:",
      "              - 1",
      "            IsStarterAgent: true",
      "          - Prompt: ${11:Tell me more about the findings}",
      "        Settings:",
      "          OrchestratorSkill: DefaultAgentOrchestrator",
      "          Model: ${12|gpt-4o,gpt-4.1|}",
      "          Instructions: >-",
      "            # Mission",
      "            ${13:You are an interactive security analyst agent.}",
      "",
      "            # Interactive Approach",
      "            - Listen and respond to the analyst's specific questions",
      "            - Ask clarifying questions when the request is ambiguous",
      "            - Provide targeted answers rather than comprehensive reports",
      "",
      "            # Available Skills",
      "            - ${14:SkillName}: ${15:Skill description}",
      "",
      "        ChildSkills:",
      "          - ${14:SkillName}",
      "$0"
    ]
  },
  "Security Copilot Skill (LogicApp)": {
    "prefix": "sc-skill-logicapp",
    "description": "Add a LogicApp skill to an existing plugin",
    "body": [
      "      - Name: ${1:SkillName}",
      "        DisplayName: \"${2:Skill Display Name}\"",
      "        Description: >",
      "          ${3:Skill description.}",
      "        Inputs:",
      "          - Name: ${4:inputParam}",
      "            Description: ${5:Input description}",
      "            Required: true",
      "        Settings:",
      "          SubscriptionId: ${6:<YOUR-SUBSCRIPTION-ID>}",
      "          ResourceGroup: ${7:<YOUR-RESOURCE-GROUP>}",
      "          WorkflowName: ${8:MyLogicApp}",
      "          TriggerName: ${9:manual}",
      "$0"
    ]
  },
  "Security Copilot SkillGroup (MCP)": {
    "prefix": "sc-skill-mcp",
    "description": "Add an MCP skill group to an existing plugin",
    "body": [
      "  - Format: MCP",
      "    Settings:",
      "      Endpoint: ${1:https://example.com/api/mcp}",
      "      TimeoutInSeconds: ${2:120}",
      "      AllowedTools: ${3:tool_name_1, tool_name_2}",
      "$0"
    ]
  },
  "Security Copilot Skill (Agent)": {
    "prefix": "sc-skill-agent",
    "description": "Add an Agent orchestration skill",
    "body": [
      "      - Name: ${1:AgentSkill}",
      "        DisplayName: \"${2:Agent Skill}\"",
      "        Description: >",
      "          ${3:Agent skill description.}",
      "        Interfaces:",
      "          - ${4|Agent,InteractiveAgent|}",
      "        Settings:",
      "          Model: ${5|gpt-4o,gpt-4.1|}",
      "          Instructions: >-",
      "            # Mission",
      "            ${6:Agent mission.}",
      "",
      "            # Workflow",
      "            1. ${7:Step 1}",
      "",
      "            # Output",
      "            ${8:Output format.}",
      "        ChildSkills:",
      "          - ${9:ChildSkillName}",
      "$0"
    ]
  }
}
